APP_NAME=IncidentPilot AI
APP_VERSION=0.9.0
ENVIRONMENT=development

DATABASE_URL=postgresql+psycopg://incidentpilot:incidentpilot@localhost:5432/incidentpilot
TEST_DATABASE_URL=postgresql+psycopg://incidentpilot:incidentpilot@localhost:5432/incidentpilot_test
REDIS_URL=redis://localhost:6379/0

LOG_LEVEL=INFO

EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384
EMBEDDING_CACHE_DIR=/cache/sentence-transformers

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT_SECONDS=240
OLLAMA_KEEP_ALIVE=10m
OLLAMA_NUM_CTX=8192
OLLAMA_TEMPERATURE=0.0
OLLAMA_NUM_PREDICT=1800
OLLAMA_SEED=42

RCA_MAX_LOGS=50
RCA_MAX_METRICS=50
RCA_MAX_DEPLOYMENTS=20
RCA_RUNBOOK_TOP_K=5
